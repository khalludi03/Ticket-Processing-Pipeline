# ── Database ───────────────────────────────────────────────────────────────────
# Local: postgresql://postgres@127.0.0.1:5433/ticket_pipeline  (docker compose up -d)
# Prod:  connection URL from your hosted Postgres provider
DATABASE_URL=postgresql://postgres@127.0.0.1:5433/ticket_pipeline
DATABASE_PASSWORD=testingpassword

# ── AWS (LocalStack for all environments) ──────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── SQS (LocalStack — docker compose up -d) ───────────────────────────────────
SQS_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/dev-tickets-queue
SQS_DLQ_URL=http://localhost:4566/000000000000/dev-tickets-dlq

# ── Seed ───────────────────────────────────────────────────────────────────────
SEED_API_KEY=local-dev-api-key

# ── Encryption (AES-256) ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Epic 3+ ────────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
