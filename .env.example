# ── Required — Epic 1 ──────────────────────────────────────────────────────────
# Session-mode pooler URL (IPv4 accessible, supports DDL)
# Format: postgresql://postgres.[project-ref]@[pooler-host]:5432/postgres
DATABASE_URL=postgresql://postgres.<project-ref>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_PASSWORD=your-supabase-db-password

AWS_REGION=us-east-1
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/tickets-queue
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789/tickets-dlq

# Optional — not needed when running on Lambda with an IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Seed ───────────────────────────────────────────────────────────────────────
SEED_API_KEY=local-dev-api-key

# ── Test ───────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://postgres.<test-project-ref>@aws-1-<region>.pooler.supabase.com:5432/postgres
TEST_DATABASE_PASSWORD=your-test-db-password

# ── Epic 3+ (not validated on boot yet) ───────────────────────────────────────
# LANGSMITH_API_KEY=
# BEDROCK_MODEL_ID=
